{
  "name": "@hypr/mobile",
  "main": "expo-router/entry",
  "version": "0.0.1",
  "description": "Hypr Expo mobile shell backed by the Rust mobile bridge.",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "prebuild": "expo prebuild --no-install",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/ui": "~55.0.11",
    "@hypr/db": "workspace:*",
    "@hypr/db-runtime": "workspace:*",
    "@hypr/db-react": "workspace:*",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/elements": "^2.9.10",
    "@react-navigation/native": "^7.1.33",
    "@tailwindcss/postcss": "^4.2.2",
    "clsx": "^2.1.1",
    "expo": "~55.0.14",
    "expo-constants": "~55.0.13",
    "expo-device": "~55.0.15",
    "expo-font": "~55.0.6",
    "expo-glass-effect": "~55.0.10",
    "expo-image": "~55.0.8",
    "expo-linking": "~55.0.12",
    "expo-router": "~55.0.12",
    "expo-splash-screen": "~55.0.17",
    "expo-status-bar": "~55.0.5",
    "expo-symbols": "~55.0.7",
    "expo-system-ui": "~55.0.15",
    "expo-web-browser": "~55.0.14",
    "nativewind": "5.0.0-preview.2",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-css": "0.0.0-nightly.5ce6396",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.2",
    "tailwind-merge": "^2.6.1",
    "tailwindcss": "^4.2.2",
    "uniffi-bindgen-react-native": "0.29.3-1"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~5.9.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hypr/char"
  },
  "author": "Hypr",
  "license": "UNLICENSED",
  "homepage": "https://char.com",
  "engines": {
    "node": ">=20"
  },
  "codegenConfig": {
    "name": "NativeMobileBridge",
    "type": "modules",
    "jsSrcsDir": "src/bridge",
    "android": {
      "javaPackageName": "com.hypr.mobile"
    },
    "outputDir": {
      "ios": "ios/generated",
      "android": "android/generated"
    }
  },
  "resolutions": {
    "lightningcss": "1.30.1"
  },
  "private": true
}
