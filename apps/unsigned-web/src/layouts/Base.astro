---
import "../styles.css";
import { SEO } from "astro-seo";

const title = "Unsigned Char";
const description =
  "Unsigned Char is a bot-free meeting note taker for macOS that runs fully on device. It's open source and free to use forever.";
const url = "https://unsigned.char.com";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <link rel="alternate icon" type="image/svg+xml" href="/icon.svg" />
    <SEO title={title} description={description} canonical={url} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif&display=swap"
      rel="stylesheet"
    />
    <style>html { background: #fff }</style>
  </head>
  <body class="min-h-screen bg-white">
    <div class="flex min-h-screen flex-col">
      <div
        class="w-full border-b border-neutral-200 bg-neutral-50 px-4 py-3 text-center font-serif text-base text-neutral-700"
      >
        <span>Unsigned Char is an on-device version of </span>
        <a
          href="https://char.com"
          target="_blank"
          rel="noopener noreferrer"
          class="underline decoration-neutral-700 decoration-[1.5px] underline-offset-4"
          >Char</a
        >
        <span> that is free for everyone to use.</span>
      </div>

      <main
        class="flex w-full flex-1 items-center justify-center bg-white py-12 font-serif text-neutral-950"
      >
        <slot />
      </main>
    </div>
  </body>
</html>
